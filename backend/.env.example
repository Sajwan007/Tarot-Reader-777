# Server Configuration
PORT=5000
NODE_ENV=development

# Supabase Database
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
